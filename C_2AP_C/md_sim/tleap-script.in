source leaprc.RNA.OL3
source leaprc.water.tip3p
loadOff R2AP.off
loadamberparams frcmod.R2AP

dinic = sequence { C5 R2AP C3 }

solvatebox dinic SPCBOX 10 iso
addions dinic Na+ 0
addions dinic Na+ 8
addions dinic Cl- 8

savepdb dinic dinic_solv.pdb

saveamberparm dinic dinic_solv.prmtop dinic_solv.inpcrd


quit
